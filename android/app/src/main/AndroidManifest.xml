<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for AdMob ads -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- 
        SMS permissions required for UPI subscription detection.
        READ_SMS: Read existing SMS to detect past UPI transactions.
        RECEIVE_SMS: Listen for new UPI transaction notifications in real-time.
        
        PRIVACY POLICY REQUIRED: Declare in Play Console privacy policy.
        All SMS processing happens locally on-device.
        Only SMS containing UPI-related keywords are processed.
        No SMS data is transmitted or stored externally.
    -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    
    <!-- Required for notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Required for alarm vibration -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- 
        REQUEST_IGNORE_BATTERY_OPTIMIZATIONS allows the app to request exemption from battery optimization.
        This is critical for alarm reliability as battery optimization can prevent alarms from triggering.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- 
        SCHEDULE_EXACT_ALARM is allowed for subscription reminders.
        This is used for user-initiated alarms (subscription renewal reminders).
        Falls back to inexact alarms if not granted.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    
    <!-- 
        USE_EXACT_ALARM is a fallback for Android 13+ when SCHEDULE_EXACT_ALARM is not granted.
        This permission doesn't require user approval for alarm/reminder apps.
    -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    
    <!-- Required to restart alarms after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Query intents for Android 11+ (Package Visibility) -->
    <queries>
        <!-- UPI Payment Apps -->
        <package android:name="com.phonepe.app" />
        <package android:name="com.google.android.apps.nbu.paisa.user" />
        <package android:name="net.one97.paytm" />
        
        <!-- Banking Apps -->
        <package android:name="com.sbi.lotusintouch" />
        <package android:name="com.snapwork.hdfc" />
        <package android:name="com.csam.icici.bank.imobile" />
        <package android:name="com.axis.mobile" />
        <package android:name="com.msf.kbank.mobile" />
        
        <!-- Play Store for app subscriptions -->
        <package android:name="com.android.vending" />
        
        <!-- Intent for opening any app via deep link -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
      android:name=".MainApplication"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:allowBackup="false"
      android:theme="@style/AppTheme"
      android:usesCleartextTraffic="${usesCleartextTraffic}"
      android:supportsRtl="true">
      
      <!-- AdMob App ID - Required for ads to work -->
      <meta-data
        android:name="com.google.android.gms.ads.APPLICATION_ID"
        android:value="ca-app-pub-3990640624622013~9037064259"/>
      
      <activity
        android:name=".MainActivity"
        android:label="@string/app_name"
        android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
        android:launchMode="singleTask"
        android:windowSoftInputMode="adjustResize"
        android:theme="@style/SplashTheme"
        android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity>
      
      <!-- 
          SMS BroadcastReceiver for real-time UPI transaction detection.
          Only processes SMS containing UPI-related keywords.
      -->
      <receiver
        android:name=".sms.SmsReceiver"
        android:exported="true"
        android:permission="android.permission.BROADCAST_SMS">
        <intent-filter>
          <action android:name="android.provider.Telephony.SMS_RECEIVED" />
        </intent-filter>
      </receiver>
      
      <!-- 
          Alarm BroadcastReceiver for payment reminders.
          Triggers even when app is completely closed.
      -->
      <receiver
        android:name=".alarm.AlarmReceiver"
        android:exported="false"
        android:enabled="true">
      </receiver>
      
      <!-- Dismiss receiver for clearable alarm notifications -->
      <receiver
        android:name=".alarm.AlarmDismissReceiver"
        android:exported="false"
        android:enabled="true">
      </receiver>

      <!-- Boot receiver: reschedules alarms after device reboot -->
      <receiver
        android:name=".alarm.BootReceiver"
        android:exported="true"
        android:enabled="true">
        <intent-filter>
          <action android:name="android.intent.action.BOOT_COMPLETED" />
          <action android:name="android.intent.action.QUICKBOOT_POWERON" />
          <category android:name="android.intent.category.DEFAULT" />
        </intent-filter>
      </receiver>
    </application>
</manifest>
